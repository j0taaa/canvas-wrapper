{
  "name": "canvas-platform",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "cd apps/web && bun run dev",
    "dev:web": "cd apps/web && bun run dev",
    "dev:mobile": "cd apps/mobile && bun run dev",
    "ios:mobile": "cd apps/mobile && bun run ios",
    "android:mobile": "cd apps/mobile && bun run android",
    "build": "cd apps/web && bun run build",
    "build:web": "cd apps/web && bun run build",
    "lint": "cd apps/web && bun run lint",
    "lint:web": "cd apps/web && bun run lint",
    "typecheck:mobile": "cd apps/mobile && bun run typecheck"
  }
}
